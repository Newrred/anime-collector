---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";
import { buildUiPreferenceBootScript } from "../domain/uiPreferences";
import { THEME_META_COLORS } from "../domain/colorSystem.js";
const rawBase = String(import.meta.env.BASE_URL || "/");
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const isProd = import.meta.env.PROD;
const analyticsEnabled = isProd && import.meta.env.PUBLIC_DISABLE_VERCEL_ANALYTICS !== "1";
const normalize = (p: string | null | undefined) =>
  (String(p || "").endsWith("/") ? String(p) : `${String(p)}/`);
const toBasePath = (p: string = "") => `${base}${String(p).replace(/^\/+/, "")}`;
const isIndexPage = normalize(Astro.url.pathname) === normalize(base);
const isTierPage = normalize(Astro.url.pathname) === normalize(toBasePath("tier/"));
const isLibraryPage = normalize(Astro.url.pathname) === normalize(toBasePath("library/"));
const uiPreferenceBootScript = buildUiPreferenceBootScript();
const authReturnGuardScript = `
(() => {
  const params = new URLSearchParams(window.location.search);
  const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ""));
  const hasAuthPayload =
    params.has("code") ||
    params.has("error_description") ||
    hashParams.has("access_token") ||
    hashParams.has("error_description");
  if (!hasAuthPayload) return;

  const callback = new URL(${JSON.stringify(`${base}auth/callback/`)}, window.location.origin);
  const pathname = window.location.pathname.endsWith("/")
    ? window.location.pathname
    : \`\${window.location.pathname}/\`;

  if (pathname === callback.pathname) return;

  callback.search = window.location.search;
  callback.hash = window.location.hash;
  window.location.replace(callback.toString());
})();
`;
---
<html lang="ko" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content={THEME_META_COLORS.dark} />
    <script is:inline set:html={authReturnGuardScript}></script>
    <script is:inline set:html={uiPreferenceBootScript}></script>
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="애니 라이브러리" />
    <link rel="manifest" href={toBasePath("manifest.webmanifest")} />
    <title>MOEMOA - 개인 애니 라이브러리</title>
  </head>
  <body>
    <ClientRouter />
    <div class="app-shell">
      <main class="container page-wrap">
        <slot />
      </main>
    </div>
    {analyticsEnabled ? <Analytics /> : null}
    {isProd && <script is:inline type="module" src={toBasePath("register-sw.js")}></script>}
  </body>
</html>
